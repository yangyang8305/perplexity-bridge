# Single session token (copy from browser cookie: __Secure-next-auth.session-token)
SESSIONS=your-session-token-here
ADDRESS=127.0.0.1:8080
# Set a long random string as the local API key for your clients.
APIKEY=change-me-to-a-long-random-local-key
IS_INCOGNITO=true
# Optional: PROXY=http://127.0.0.1:2080
MAX_CHAT_HISTORY_LENGTH=10000
NO_ROLE_PREFIX=false
SEARCH_RESULT_COMPATIBLE=false
IGNORE_SEARCH_RESULT=false
IS_MAX_SUBSCRIBE=false
